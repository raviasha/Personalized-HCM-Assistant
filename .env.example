OPENAI_API_KEY=sk-your-key-here

# Supabase — required for persistent state across Render restarts
# Create a free project at https://supabase.com and paste the values below.
# Leave blank to run in local-JSON-only mode (no persistence across restarts).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
